# Robots in a House — Environment Variables
# Copy to .env.local and fill in values.

# ── Runner ──────────────────────────────────────────────
# Port for the agent runner HTTP server (default: 3100)
RUNNER_PORT=3100

# ── Next.js ─────────────────────────────────────────────
# Port for Next.js dev/prod server (default: 3000)
PORT=3000

# ── Auth ────────────────────────────────────────────────
# The runner uses Claude Max OAuth via keychain (`claude setup-token`).
# If you need to override with an API key, set it here:
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ────────────────────────────────────────────
# NODE_ENV=production
