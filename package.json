{
  "name": "robots-in-a-house",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "curl -sf -o /dev/null --max-time 1 http://localhost:3000 && { echo 'dev server already healthy on :3000 — skipping predev cleanup'; exit 0; } || { lsof -ti :3000 | xargs -r kill -9 2>/dev/null; pgrep -f 'next dev|agent-runner' | xargs -r kill -9 2>/dev/null; exit 0; }",
    "dev": "concurrently -n next,runner -c cyan,magenta \"next dev\" \"tsx server/agent-runner.ts\"",
    "dev:next": "next dev",
    "dev:runner": "tsx server/agent-runner.ts",
    "build": "next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production tsx server/start.ts",
    "start:dev": "tsx server/start.ts",
    "check": "tsx server/boot-check.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.108",
    "better-sqlite3": "^12.9.0",
    "canvas-confetti": "^1.9.4",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "next": "16.2.3",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.18.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
