# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# electron build output
/dist-electron
electron/*.js
electron/*.js.map

# compiled electron agent-runner output is generated by esbuild — don't commit

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# runtime data
/data/
/agent-workspaces/**
!/agent-workspaces/**/
!/agent-workspaces/**/CLAUDE.md
!/agent-workspaces/**/MEMORY.md

# local agent + skill state
/.claude/
/.superpowers/

# typescript
*.tsbuildinfo
next-env.d.ts
server/dev.db
uploads/
