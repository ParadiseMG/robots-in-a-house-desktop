# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# runtime data
/data/

# agent workspaces — only ship the example
/agent-workspaces/*
!/agent-workspaces/example/

# office configs — only ship the example
/config/*.office.json
!/config/example.office.json

# station config — ship default, user creates their own
/config/station.json

# local agent + skill state
/.claude/
/.superpowers/

# typescript
*.tsbuildinfo
next-env.d.ts
server/dev.db
uploads/
MEMORY.md
/launch-os/
